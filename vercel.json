{
  "version": 2,
  "builds": [
    {
      "src": "engine/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "app/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "engine/app.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "app/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app/dist/index.html"
    }
  ]
}
